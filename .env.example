# Site URL (optional — defaults to https://kamoheloculinary.co.za)
# NEXT_PUBLIC_SITE_URL=https://kamoheloculinary.co.za

# Form backend — use ONE of the following:

# Option A: Formspree (recommended for Vercel launch)
# 1. Create a form at https://formspree.io
# 2. Add FORMSPREE_FORM_ID in Vercel → Project → Settings → Environment Variables
FORMSPREE_FORM_ID=your_formspree_form_id

# Option B: Supabase (stores inquiries in Postgres)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Or use anon key with RLS insert policy on `inquiries` table:
# SUPABASE_ANON_KEY=your_anon_key

# Culinary AI (Phase 7) — optional
# Keyword search works without any API key.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Analytics (optional — no IDs committed to git)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kamoheloculinary.co.za
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Future: Supabase pgvector for semantic search upgrade
# SUPABASE_URL=...
